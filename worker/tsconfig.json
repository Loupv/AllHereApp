{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  // worker-configuration.d.ts is generated by `npm run types` (wrangler types)
  // and supplies both the `Env` binding interface and the Workers runtime types.
  "include": ["src/**/*.ts", "worker-configuration.d.ts"]
}
