<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store distribution: produces an IPA you upload to App Store
         Connect / TestFlight via Transporter. Use "ad-hoc" if you ever
         need to install on UDID-registered devices without TestFlight. -->
    <key>method</key>
    <string>app-store-connect</string>
    <key>teamID</key>
    <string>3YWPZYHW99</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>stripSwiftSymbols</key>
    <true/>
    <key>uploadSymbols</key>
    <true/>
    <key>destination</key>
    <string>export</string>
</dict>
</plist>
