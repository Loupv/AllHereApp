{
  "expo": {
    "name": "Silent Mind",
    "slug": "AllHereApp",
    "version": "1.1.8",
    "scheme": "allhere",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "assets/images/**",
      "assets/fonts/**",
      "assets/audio/Home/**",
      "assets/audio/QMPart1/Rounds/QM3_7rounds_Breath and Self-Observation/**",
      "assets/audio/QMUnguided/Words/**",
      "assets/audio/bell.mp3",
      "assets/audio/bell_short.mp3",
      "assets/audio/tick.mp3"
    ],
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00102E"
    },
    "ios": {
      "bundleIdentifier": "org.allhere.silentmind",
      "buildNumber": "1.0.19",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "3YWPZYHW99"
    },
    "android": {
      "package": "org.allhere.silentmind",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00102E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-font",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85ed60b1-9c9f-4763-a155-c826d707da9f"
      }
    }
  }
}
